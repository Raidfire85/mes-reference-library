{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: compile",
      "type": "process",
      "command": "${env:ProgramFiles}\\nodejs\\npm.cmd",
      "args": ["run", "compile"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "npm: watch",
      "type": "process",
      "command": "${env:ProgramFiles}\\nodejs\\npm.cmd",
      "args": ["run", "watch"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": "$tsc-watch"
    },
    {
      "label": "npm: build-vsix",
      "type": "process",
      "command": "${env:ProgramFiles}\\nodejs\\npm.cmd",
      "args": ["run", "build-vsix"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "npm: install-extension",
      "type": "process",
      "command": "${env:ProgramFiles}\\nodejs\\npm.cmd",
      "args": ["run", "install-extension"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
